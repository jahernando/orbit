{
  "_comment": "Hook system catalog. Loaded by core.hooks.bootstrap() at startup. See HOOKSYSTEM.md.",
  "actions": {
    "cloud_imgs_process": {
      "module": "core.commit",
      "fn": "_action_cloud_imgs_process",
      "critical": false
    },
    "cronograma_log_completed": {
      "module": "core.commit",
      "fn": "_action_cronograma_log_completed",
      "critical": false
    },
    "doctor_check_save": {
      "module": "views.doctor.doctor",
      "fn": "_action_doctor_check_save",
      "critical": true
    },
    "render_changed_background": {
      "module": "views.render.render",
      "fn": "_action_render_changed_background",
      "critical": false
    },
    "doctor_startup": {
      "module": "core.shell",
      "fn": "_action_doctor_startup",
      "critical": false
    },
    "advance_overdue_recurring": {
      "module": "core.shell",
      "fn": "_action_advance_overdue_recurring",
      "critical": false
    },
    "cloud_sync_status_check": {
      "module": "core.shell",
      "fn": "_action_cloud_sync_status_check",
      "critical": false
    },
    "untracked_check": {
      "module": "core.shell",
      "fn": "_action_untracked_check",
      "critical": false
    },
    "commit_offer": {
      "module": "core.shell",
      "fn": "_action_commit_offer",
      "critical": false
    },
    "code_update_check": {
      "module": "core.shell",
      "fn": "_action_code_update_check",
      "critical": false
    },
    "cartero_startup": {
      "module": "core.shell",
      "fn": "_action_cartero_startup",
      "critical": false
    },
    "secretary_refresh": {
      "module": "core.shell",
      "fn": "_action_secretary_refresh",
      "critical": false
    },
    "dash_background_loop_start": {
      "module": "core.shell",
      "fn": "_action_dash_background_loop_start",
      "critical": false
    },
    "ics_emit_workspace": {
      "module": "views.render.render",
      "fn": "_action_ics_emit_workspace",
      "critical": false
    },
    "ring_refresh": {
      "module": "views.ring.export",
      "fn": "_action_ring_refresh",
      "critical": false
    }
  },
  "chains": {
    "commit_pre": {
      "trigger_type": "explicit",
      "pre": [
        "cloud_imgs_process",
        "cronograma_log_completed",
        "doctor_check_save"
      ]
    },
    "commit_post": {
      "trigger_type": "explicit",
      "post": ["render_changed_background", "ics_emit_workspace", "ring_refresh"]
    },
    "shell_start": {
      "trigger_type": "temporal",
      "post": [
        "doctor_startup",
        "advance_overdue_recurring",
        "cloud_sync_status_check",
        "untracked_check",
        "commit_offer",
        "code_update_check",
        "cartero_startup",
        "ring_refresh",
        "secretary_refresh",
        "dash_background_loop_start"
      ]
    },
    "day_open": {
      "trigger_type": "temporal",
      "post": [
        "advance_overdue_recurring",
        "secretary_refresh"
      ]
    }
  },
  "bindings": {
    "commit_pre": "commit_pre",
    "commit_post": "commit_post",
    "shell_startup": "shell_start",
    "day_changed": "day_open"
  }
}
